
# IMPORT LIBRARIES

import joblib
import pandas as pd
import numpy as np
import shap
import matplotlib.pyplot as plt

# LOAD SAVED FILES

model = joblib.load("best_sepsis_model.pkl")
top_features = joblib.load("features.pkl")
X_train = joblib.load("X_train.pkl")
scaler = joblib.load("scaler.pkl")

print("="*50)
print("        SEPSIS PREDICTION SYSTEM")
print("="*50)


# SAFE INPUT FUNCTION
def safe_input(prompt, min_val=None, max_val=None):
    while True:
        try:
            value = float(input(prompt))
            if min_val is not None and value < min_val:
                print(f"Value should be greater than or equal to {min_val}")
                continue
            if max_val is not None and value > max_val:
                print(f"Value should be less than or equal to {max_val}")
                continue
            return value
        except ValueError:
            print("Invalid Input! Please enter numeric values only.")

# TAKE USER INPUT

print("\nEnter Patient Clinical Details\n")
HR = safe_input("Heart Rate (bpm): ",30,200)
O2Sat = safe_input("Oxygen Saturation (%): ",50,100)
Temp = safe_input("Temperature (°C): ",30,45)
SBP = safe_input("Systolic BP (mmHg): ",50,200)
MAP = safe_input("Mean Arterial Pressure: ",40,150)
Resp = safe_input("Respiration Rate: ",5,60)
Creatinine = safe_input("Creatinine: ",0.1,15)
Glucose = safe_input("Glucose: ",50,500)
Lactate = safe_input("Lactate: ",0.5,15)
Age = safe_input("Age: ",0,120)

# CREATE PATIENT DATAFRAME


new_patient = pd.DataFrame({

    "HR":[HR],
    "O2Sat":[O2Sat],
    "Temp":[Temp],
    "SBP":[SBP],
    "MAP":[MAP],
    "Resp":[Resp],
    "Creatinine":[Creatinine],
    "Glucose":[Glucose],
    "Lactate":[Lactate],
    "Age":[Age]

})

# SCALE INPUT DATA


scaled_patient = scaler.transform(new_patient)
print("\nPatient data received successfully.")
print(new_patient)

# PREDICTION

try:
    # Check if model requires scaled data
    if "LogisticRegression" in str(type(model)) or "SVC" in str(type(model)):
        prediction = model.predict(scaled_patient)[0]
        probability = model.predict_proba(scaled_patient)[0][1]
    else:
        prediction = model.predict(new_patient)[0]
        probability = model.predict_proba(new_patient)[0][1]

except Exception as e:
    print("Prediction Failed!")
    print(e)
    exit()

# RISK LEVEL

if probability >= 0.70:
    risk = "HIGH RISK"
    emoji = "🔴"
elif probability >= 0.40:
    risk = "MODERATE RISK"
    emoji = "🟡"
else:
    risk = "LOW RISK"
    emoji = "🟢"

# CONFIDENCE LEVEL


confidence = max(probability, 1 - probability)
if confidence >= 0.90:
    confidence_level = "Very High"

elif confidence >= 0.75:
    confidence_level = "High"
elif confidence >= 0.60:
    confidence_level = "Medium"
else:
    confidence_level = "Low"


# DOCTOR STYLE REPORT

print("\n")
print("=" * 60)
print("        SEPSIS RISK ASSESSMENT REPORT")
print("=" * 60)
print(f"\nPrediction   : {'Sepsis Likely' if prediction == 1 else 'No Sepsis'}")
print(f"Risk Probability  : {probability*100:.2f}%")
print(f"{emoji} Risk Level      : {risk}")
print(f"Confidence Level  : {confidence_level}")
print("\nClinical Interpretation:")
if prediction == 1:
    print("• Patient shows clinical indicators associated with sepsis.")
    print("• Immediate medical evaluation is recommended.")
    print("• Continuous monitoring of vital signs is advised.")
else:
    print("• No strong indicators of sepsis detected.")
    print("• Continue routine monitoring.")
    print("• Reassess if symptoms worsen.")

# DISPLAY PATIENT VALUES


print("\nEntered Patient Details")
print("-" * 40)

for col in new_patient.columns:
    print(f"{col:15} : {new_patient.iloc[0][col]}")

